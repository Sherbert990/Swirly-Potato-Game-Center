ENV=dev
SECRET_KEY=change-me-in-prod
# MySQL for real dev/prod. SQLite also works for zero-setup local dev:
#   DATABASE_URL=sqlite:///./dev.sqlite
DATABASE_URL=mysql+pymysql://root@127.0.0.1:3306/gamecenter?charset=utf8mb4
# Tests use a SEPARATE throwaway DB (schema is dropped at start/end — never point
# this at a DB with data you care about). Defaults to local SQLite if unset:
TEST_DATABASE_URL=sqlite:///./backend_test.sqlite
# Or a throwaway MySQL:
# TEST_DATABASE_URL=mysql+pymysql://root@127.0.0.1:3306/gamecenter_test?charset=utf8mb4
